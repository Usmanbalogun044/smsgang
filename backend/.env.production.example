# SMS Gang Production Environment Variables
# Copy this file to .env and fill in your values

APP_NAME=SMSGang
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:YOUR_KEY_HERE
APP_URL=https://smsgang.com

LOG_CHANNEL=telegram
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ============================================
# EXTERNAL MYSQL CONFIGURATION
# ============================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=smsgang
DB_USERNAME=smsgang
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# ============================================
# EXTERNAL REDIS CONFIGURATION
# ============================================
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=predis
REDIS_HOST=localhost
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================
# PAYMENT & EXTERNAL SERVICES
# ============================================
FRONTEND_URL=https://smsgang.com
ADMIN_URL=https://admin.smsgang.com
VERIFY_PAYMENT_URL=https://smsgang.com/orders

FIVESIM_API_KEY=YOUR_5SIM_API_KEY
LENDOVERIFY_API_KEY=YOUR_LENDOVERIFY_KEY
LENDOVERIFY_BASE_URL=https://api.lendoverify.com

CURRENCY_API_KEY=YOUR_CURRENCY_API_KEY
CURRENCY_API_HOST=api.exchangerate-api.com

# ============================================
# NOTIFICATIONS
# ============================================
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

CRESTPANEL_API_KEY=b060ba5596204f2bc0d4616fa1c825fe